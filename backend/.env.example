# Servidor
PORT=3000

# OpenAI — obrigatorio para analise real com GPT-4o
# Sem esta chave, o backend opera em modo simulado
OPENAI_API_KEY=sk-...

# Redis — opcional; sem configuracao, usa store em memoria
REDIS_URL=redis://localhost:6379

# PostgreSQL com pgvector — opcional; sem configuracao, usa store em memoria
DATABASE_URL=postgresql://user:password@localhost:5432/contracts_db
# JWT
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_in_production_refresh

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Server
PORT=3000
